# ── Basis environment ────────────────────────────────────────────────
# Copy to .env.local and fill in what you have. Everything is optional:
# with no keys at all, Basis runs in clearly-labeled Demo Mode using
# deterministic synthetic market data.

# SQLite database file (created automatically). Default: ./data/basis.db
# DATABASE_PATH=./data/basis.db

# Secret used to sign session cookies. Generate one:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Required in production; a dev-only fallback is used otherwise.
SESSION_SECRET=

# Finnhub API key (free tier: quotes, search, company profiles, news).
# Server-side only — never exposed to the browser. https://finnhub.io
FINNHUB_API_KEY=

# Daily historical candles are fetched from Stooq (free, no key needed).
# Set to "false" to disable network candle fetching entirely.
# STOOQ_ENABLED=true

# Force demo mode even if keys are present ("true"/"false").
# DEMO_MODE=

# Optional grounded AI research assistant (Anthropic). Feature is hidden
# when unset; the platform is fully usable without it.
ANTHROPIC_API_KEY=
